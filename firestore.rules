rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && incoming().uid == userId;
      allow update: if isOwner(userId);
    }

    match /plants/{plantId} {
      allow read: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }
  }
}
